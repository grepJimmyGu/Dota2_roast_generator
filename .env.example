# Stratz GraphQL API token — get yours at https://stratz.com/api
STRATZ_TOKEN=your_stratz_token_here

# OpenAI API key — required for the AI roast/critique feature
OPENAI_API_KEY=sk-...

# Comma-separated list of allowed CORS origins.
# Local dev default: http://localhost:3000
# Production: set to your Vercel frontend URL (e.g. https://your-app.vercel.app)
ALLOWED_ORIGINS=http://localhost:3000

# SQLite DB file path (default: dota2_mmr.db in working directory)
# On Railway with a persistent volume mounted at /data, set to: /data/dota2_mmr.db
# For ephemeral demo deploys, leave as default (DB resets on redeploy, data re-fetches from Stratz)
DB_PATH=dota2_mmr.db

# Cache freshness window in hours (default: 6)
# CACHE_FRESHNESS_HOURS=6
