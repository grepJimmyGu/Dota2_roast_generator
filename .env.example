# Copy this file to .env and fill in your values

# Stratz GraphQL API token — get yours at https://stratz.com/api
STRATZ_TOKEN=your_stratz_token_here

# OpenAI API key — required for the AI roast/critique feature
OPENAI_API_KEY=sk-...

# Optional: override cache freshness window (default 6 hours)
# CACHE_FRESHNESS_HOURS=6
